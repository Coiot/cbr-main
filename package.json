    "medium-zoom": "^1.1.0",
    "nprogress": "^0.2.0",
    "prismjs": "^1.30.0",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.26",
    "dotenv": "^16.4.5",
    "sharp": "^0.35.0",
    "supabase": "^2.109.1",
    "vite": "^7.3.5",
    "vuepress": "2.0.0-rc.26",
    "yaml-front-matter": "^4.0.0"
  }
