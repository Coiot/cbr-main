{
  "name": "vuepress-blog",
  "description": "Civ Battle Royale episode archive and community site",
  "version": "0.11.0-beta",
  "license": "MIT",
  "engines": {
    "node": ">=20.19 <23"
  },
  "resolutions": {
    "js-yaml": "^3.15.0",
    "vite": "^7.3.5"
  },
  "scripts": {
    "predev": "npm run build:album-data",
    "dev": "vuepress dev src",
    "build:album-data": "node scripts/build-album-data.js",
    "build:social-card": "node scripts/build-home-social-card.js",
    "build:episode-snapshots": "node scripts/build-episode-snapshots.js",
    "build": "npm run build:album-data && npm run build:social-card && npm run build:episode-snapshots && vuepress build src",
    "build:map-cache": "node scripts/build-community-map-cache.js",
    "build:supporters": "node scripts/build-supporters-image.js"
  },
  "dependencies": {
